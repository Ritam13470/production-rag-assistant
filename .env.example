# Production RAG Assistant environment template
# Copy this file to .env and replace the placeholder with your real Gemini API key.
#
# Never commit your real .env file to GitHub.

GOOGLE_API_KEY=your_api_key_here

# Optional LangSmith tracing for local development with safe/sample documents.
# Keep this disabled for public demos unless trace privacy is handled.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=production-rag-assistant
